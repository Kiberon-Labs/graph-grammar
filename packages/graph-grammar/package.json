{
  "name": "graph-grammar",
  "version": "1.0.0",
  "description": "A fast, framework-agnostic graph rewriting / graph grammar engine: pattern matching (subgraph isomorphism), rule application with edge embedding, NACs, property expressions, and stochastic/parallel application strategies.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "graph",
    "graph-grammar",
    "graph-rewriting",
    "graph-transformation",
    "subgraph-isomorphism",
    "l-system",
    "rewriting",
    "generative"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./examples": {
      "types": "./dist/examples.d.ts",
      "import": "./dist/examples.js"
    }
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "vitest bench --run"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsup": "^8.5.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.9"
  }
}
