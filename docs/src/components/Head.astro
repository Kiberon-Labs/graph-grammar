---
// Extends Starlight's default <head> with Open Graph / Twitter card image tags.
// Starlight already emits og:title/description/url and twitter:card; the missing
// piece is the image. We use a branded card showing a real populated graph
// rendered by the React editor (public/og-graph.jpg), plus explicit twitter
// title/description (per page).
import Default from '@astrojs/starlight/components/Head.astro'

const { entry } = Astro.locals.starlightRoute
const base = import.meta.env.BASE_URL // always begins and ends with '/'
const ogPath = `${base}og-graph.jpg`
// Social crawlers require an absolute URL; `Astro.site` is set in the deploy.
const ogImage = Astro.site ? new URL(ogPath, Astro.site).href : ogPath
const alt = 'Graph Grammar — a populated rewrite graph in the visual workbench'
---

<Default />
<meta property="og:image" content={ogImage} />
<meta property="og:image:type" content="image/jpeg" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={alt} />
<meta name="twitter:image" content={ogImage} />
<meta name="twitter:image:alt" content={alt} />
<meta name="twitter:title" content={entry.data.title} />
{entry.data.description && <meta name="twitter:description" content={entry.data.description} />}
